<Window x:Class="BeamNGTextureFixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="BeamNG Missing Texture Fixer"
        Height="802"
        Width="1351"
        MinHeight="450"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}">

    <DockPanel LastChildFill="True" Margin="16">

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="10"
                Padding="12"
                Margin="0,12,0,0">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                       Text="{Binding StatusText}"
                       Foreground="{StaticResource MutedForegroundBrush}"
                       FontSize="13"
                       VerticalAlignment="Center" />

                    <Button DockPanel.Dock="Right"
                            Content="Abort"
                            Margin="12,0,0,0"
                            Padding="12,4"
                            MinHeight="28"
                            Command="{Binding AbortCommand}"
                            Visibility="{Binding CanAbort, Converter={StaticResource BoolToVisibilityConverter}}" />
                </DockPanel>

                <ProgressBar Margin="0,8,0,0"
                     Height="6"
                     Minimum="0"
                     Maximum="{Binding ProgressMaximum}"
                     Value="{Binding ProgressValue}"
                     IsIndeterminate="{Binding IsProgressIndeterminate}"
                     Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="16"
                    Padding="0"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="6"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource BeamAccentBrush}"
                            CornerRadius="16,16,0,0"/>

                    <Grid Grid.Row="1" Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Source="Assets/beamng_logo.png"
                               Width="54"
                               Height="54"
                               Margin="0,0,16,0"
                               VerticalAlignment="Top"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="BeamNG Missing Texture Fixer"
                                       FontSize="28"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="Scan mod zip files, compare against current and old content, and build fixed zips only when needed."
                                       Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="16"
                    Padding="16"
                    Margin="0,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Old BeamNG Content Folder"
                               VerticalAlignment="Center"/>
                    <Grid Grid.Row="0" Grid.Column="1" Margin="12,0">
                        <TextBox x:Name="OldContentFolderTextBox"
                                   Text="{Binding OldContentFolder, UpdateSourceTrigger=PropertyChanged}"
                                    Cursor="Hand"
                                    PreviewMouseLeftButtonDown="OldContentFolder_Click"/>
                        <TextBlock Text="Source for recovering missing textures from older BeamNG content"
                                   Foreground="#7F8792"
                                   Margin="12,7,36,7"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=OldContentFolderTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>


                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Content="Clear"
                            Command="{Binding ClearOldCommand}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Margin="0,12,0,0"
                               Text="Current BeamNG Content Folder"
                               VerticalAlignment="Center"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="12,12,12,0">
                        <TextBox x:Name="CurrentContentFolderTextBox"
                                  Text="{Binding CurrentContentFolder, UpdateSourceTrigger=PropertyChanged}"
                                  Cursor="Hand"
                                  PreviewMouseLeftButtonDown="CurrentContentFolder_Click"/>
                        <TextBlock Text="Used to detect textures already provided by the current game"
                                   Foreground="#7F8792"
                                   Margin="12,7,36,7"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=CurrentContentFolderTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,12,0,0"
                            Content="Clear"
                            Command="{Binding ClearCurrentCommand}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Margin="0,12,0,0"
                               Text="Target Mod Zip(s)"
                               VerticalAlignment="Center"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="12,12,12,0">
                        <TextBox x:Name="SelectedModsTextBox"
                                     Text="{Binding SelectedModsDisplay}"
                                     IsReadOnly="True"
                                     Cursor="Hand"
                                     PreviewMouseLeftButtonDown="SelectedModsTextBox_PreviewMouseLeftButtonDown" />
                        <TextBlock Text="Select one or more target mod zip files to scan and fix"
                                   Foreground="#7F8792"
                                   Margin="12,7,36,7"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=SelectedModsTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Row="2"
                            Grid.Column="2"
                            Margin="0,12,0,0"
                            Content="Clear"
                            Command="{Binding ClearModsCommand}" />

                    <Grid Grid.Row="3"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Margin="0,18,0,0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0"
                                    Orientation="Horizontal">

                            <Button Content="Scan Mod(s)"
                                    Width="99"
                                    Height="36"
                                    Margin="0,0,10,10"
                                    Command="{Binding ScanCommand}" />

                            <Button Content="Build Fixed Mod(s)"
                                    Width="120"
                                    Height="36"
                                    Margin="0,0,10,10"
                                    Command="{Binding BuildCommand}" />

                            <Button Content="Do Extra Passes (May fix more textures)"
                                    Width="240"
                                    Height="36"
                                    Margin="0,0,10,10"
                                    Command="{Binding AggressivePassCommand}" />
                        </WrapPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,6,0,0">

                            <TextBlock Text="Build Output"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <WrapPanel Orientation="Horizontal">

                                <RadioButton Content='Create new mod with "fixed" attached to the name'
                                             GroupName="BuildOutputMode"
                                             IsChecked="{Binding IsOutputModeNewFixed}"
                                             Foreground="White"
                                             Margin="0,0,18,8">
                                    <RadioButton.ToolTip>
                                        <ToolTip Content='Builds a separate mod zip and keeps the original zip untouched. The new file will be named like the original mod with "fixed" added to the name, so you can test the repaired version without overwriting the source mod.'/>
                                    </RadioButton.ToolTip>
                                </RadioButton>

                                <RadioButton Content="Replace original mod"
                                             GroupName="BuildOutputMode"
                                             IsChecked="{Binding IsOutputModeReplaceOriginal}"
                                             Foreground="White"
                                             Margin="0,0,18,8">
                                    <RadioButton.ToolTip>
                                        <ToolTip Content="Builds the repaired mod and replaces the original zip in place. Use this when you want BeamNG to keep loading the same mod filename/location, but with the repaired contents instead."/>
                                    </RadioButton.ToolTip>
                                </RadioButton>

                                <RadioButton Content='Create new mod with with "Fixed" and attach "disabled" to end of old mod'
                                             GroupName="BuildOutputMode"
                                             IsChecked="{Binding IsOutputModeNewFixedIgnored}"
                                             Foreground="White"
                                             Margin="0,0,18,8">
                                    <RadioButton.ToolTip>
                                        <ToolTip Content='Builds a separate repaired mod, adds "Fixed" to the new name, and saves it with a disabled ending so BeamNG should ignore it until you manually rename it back. Useful for staging, backup, or manual review before enabling the repaired mod.'/>
                                    </RadioButton.ToolTip>
                                </RadioButton>

                                <RadioButton x:Name="ReplaceAndMoveOriginalsRadio"
                                             Content="Replace original mod and move original zip(s) to custom location"
                                             GroupName="BuildOutputMode"
                                             IsChecked="{Binding IsOutputModeReplaceAndMoveOriginals}"
                                             Foreground="White"
                                             Margin="0,0,18,8"
                                             Visibility="Collapsed">
                                            
                                    <RadioButton.ToolTip>
                                        <ToolTip Content="Builds the repaired mod into the original mod's location, then moves the original zip file(s) to a custom folder you choose. This is useful when you want the repaired mod active in BeamNG, while keeping the old original zip stored somewhere safe outside any BeamNG-readable mods/content location."/>
                                    </RadioButton.ToolTip>
                                </RadioButton>
                            </WrapPanel>

                            <Grid Margin="0,2,0,0"
                                 Visibility="{Binding IsChecked, ElementName=ReplaceAndMoveOriginalsRadio, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" Margin="0,0,12,0">
                                    <TextBox x:Name="OriginalModsOutputFolderTextBox"
                                             Text="{Binding OriginalModsOutputFolder, UpdateSourceTrigger=PropertyChanged}"
                                             Cursor="Hand"
                                             PreviewMouseLeftButtonDown="OriginalModsOutputFolder_Click"/>

                                    <TextBlock Text="Choose where the original zip(s) should be moved after replacement. Do not choose a BeamNG mods/content folder."
                                               Foreground="#7F8792"
                                               Margin="12,7,36,7"
                                               TextWrapping="Wrap"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=OriginalModsOutputFolderTextBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <Button Grid.Column="1"
                                        Content="Clear"
                                        Command="{Binding ClearOriginalModsOutputFolderCommand}" />
                            </Grid>
                        </StackPanel>

                        <WrapPanel Grid.Row="2"
                                   Orientation="Horizontal"
                                   Margin="0,10,0,-5">
                            <CheckBox Content="Guess new current additional texture names"
                                      IsChecked="{Binding UseNormalizedCurrentContentFixes}"
                                      Foreground="White"
                                      Margin="0,0,18,8"/>

                            <CheckBox Content="Use same texture names from different locations"
                                      IsChecked="{Binding UseSameBasenameCurrentContentFixes}"
                                      Foreground="White"
                                      Margin="0,0,18,8"/>

                            <CheckBox Content="Prioritize Fixing with Old Textures"
                                      IsChecked="{Binding PreferOldContentRecovery}"
                                      Foreground="White"
                                      Margin="0,0,18,8"/>
                        </WrapPanel>

                    </Grid>

                </Grid>
            </Border>

            <TabControl Grid.Row="3"
                        Margin="0,0,0,0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource ControlBorderBrush}"
                        BorderThickness="1"
                        SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}">

                <TabItem Header="Summary">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <TextBlock Text="{Binding SummaryText}"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <Border Grid.Row="2"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Batch Summary"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10"/>

                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding BatchResults}"
                                          SelectedItem="{Binding SelectedBatchResult, Mode=TwoWay}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          HeadersVisibility="Column"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          VirtualizingPanel.CacheLength="2"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Mod Zip" Binding="{Binding ModName}" Width="220"/>
                                        <DataGridTextColumn Header="Material Files" Binding="{Binding MaterialFiles}" Width="100"/>
                                        <DataGridTextColumn Header="Refs" Binding="{Binding TextureRefs}" Width="80"/>
                                        <DataGridTextColumn Header="Present In Mod" Binding="{Binding PresentInMod}" Width="110"/>
                                        <DataGridTextColumn Header="Current Content" Binding="{Binding SatisfiedByCurrent}" Width="110"/>
                                        <DataGridTextColumn Header="References to Fix" Binding="{Binding ResolvedFromOld}" Width="135"/>
                                        <DataGridTextColumn Header="Textures Copied" Binding="{Binding FixesMade}" Width="120"/>
                                        <DataGridTextColumn Header="Build Status" Binding="{Binding BuildStatus}" Width="100"/>
                                        <DataGridTextColumn Header="Fixes Made" Binding="{Binding FixesMade}" Width="100"/>
                                        <DataGridTextColumn Header="Built Zip" Binding="{Binding OutZip}" Width="240"/>
                                        <DataGridTextColumn Header="Aggressive Ran" Binding="{Binding AggressivePassRan}" Width="110"/>
                                        <DataGridTextColumn Header="Aggressive Status" Binding="{Binding AggressivePassStatus}" Width="140"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="First Pass">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38.627"/>
                            <RowDefinition Height="27.373"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="16"
                                Grid.RowSpan="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Selected Mod"
                                           VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding BatchResults}"
                                          SelectedItem="{Binding SelectedBatchResult, Mode=TwoWay}"
                                          DisplayMemberPath="ModName"
                                          VerticalAlignment="Center"/>

                                <Button Grid.Column="4"
                                        Content="Export CSV Report"
                                        Height="30"
                                        Command="{Binding ExportTextureReportCommand}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="First Pass Result"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,-19,0,29"/>

                                <DataGrid Grid.RowSpan="2"
                                          Margin="0,10,0,0"
                                          ItemsSource="{Binding DetailRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          VirtualizingPanel.CacheLength="2"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Material File" Binding="{Binding MaterialFile}" Width="180"/>
                                        <DataGridTextColumn Header="Mode" Binding="{Binding ParseMode}" Width="90"/>
                                        <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="140"/>
                                        <DataGridTextColumn Header="Stage" Binding="{Binding StageIndex}" Width="60"/>
                                        <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="120"/>
                                        <DataGridTextColumn Header="Original Path" Binding="{Binding OriginalPath}" Width="260"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                        <DataGridTextColumn Header="Match Type" Binding="{Binding MatchType}" Width="160"/>
                                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="240"/>
                                        <DataGridTextColumn Header="New Path" Binding="{Binding NewPath}" Width="300"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Second Pass">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38.627"/>
                            <RowDefinition Height="27.373"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="16"
                                Grid.RowSpan="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Selected Mod"
                                           VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding BatchResults}"
                                          SelectedItem="{Binding SelectedBatchResult, Mode=TwoWay}"
                                          DisplayMemberPath="ModName"
                                          VerticalAlignment="Center"/>

                                <Button Grid.Column="4"
                                        Content="Export CSV Report"
                                        Height="30"
                                        Command="{Binding ExportMaterialReportCommand}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Second Pass Result"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,-19,0,29"/>

                                <DataGrid Grid.RowSpan="2"
                                          Margin="0,10,0,0"
                                          ItemsSource="{Binding SecondPassRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          VirtualizingPanel.CacheLength="2"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="180"/>
                                        <DataGridTextColumn Header="Ref Count" Binding="{Binding ReferenceCount}" Width="80"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="180"/>
                                        <DataGridTextColumn Header="Defined In" Binding="{Binding DefinitionPath}" Width="300"/>
                                        <DataGridTextColumn Header="Definition Origin" Binding="{Binding DefinitionOrigin}" Width="120"/>
                                        <DataGridTextColumn Header="Color" Binding="{Binding ColorMap}" Width="220"/>
                                        <DataGridTextColumn Header="Normal" Binding="{Binding NormalMap}" Width="220"/>
                                        <DataGridTextColumn Header="Specular" Binding="{Binding SpecularMap}" Width="220"/>
                                        <DataGridTextColumn Header="Generated" Binding="{Binding GeneratedDefinition}" Width="120"/>
                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="320"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <TextBlock Text="{Binding SecondPassSummaryText}"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Third Pass">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38.627"/>
                            <RowDefinition Height="27.373"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="16"
                                Grid.RowSpan="2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="170"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="Selected Mod"
                                           VerticalAlignment="Center"/>

                                <ComboBox Grid.Column="2"
                                          ItemsSource="{Binding BatchResults}"
                                          SelectedItem="{Binding SelectedBatchResult, Mode=TwoWay}"
                                          DisplayMemberPath="ModName"
                                          VerticalAlignment="Center"/>

                                <Button Grid.Column="4"
                                        Content="Export CSV Report"
                                        Height="30"
                                        Command="{Binding ExportThirdPassReportCommand}"
                                        VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Border Grid.Row="3"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Third Pass Result"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,-19,0,29"/>

                                <DataGrid Grid.RowSpan="2"
                                          Margin="0,10,0,0"
                                          ItemsSource="{Binding ThirdPassRows}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.ScrollUnit="Pixel"
                                          VirtualizingPanel.CacheLength="2"
                                          ScrollViewer.CanContentScroll="True"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Material" Binding="{Binding MaterialName}" Width="180"/>
                                        <DataGridTextColumn Header="Pre-Status" Binding="{Binding PreStatus}" Width="160"/>
                                        <DataGridTextColumn Header="Should Localize" Binding="{Binding ShouldLocalize}" Width="120"/>
                                        <DataGridTextColumn Header="Localaization Status" Binding="{Binding ActionTaken}" Width="180"/>
                                        <DataGridTextColumn Header="Imported From" Binding="{Binding ImportedFrom}" Width="320"/>
                                        <DataGridTextColumn Header="Injected Into" Binding="{Binding InjectedInto}" Width="260"/>
                                        <DataGridTextColumn Header="Texture Files Referenced" Binding="{Binding TextureFilesReferenced}" Width="150"/>
                                        <DataGridTextColumn Header="Textures Copied" Binding="{Binding TexturesCopied}" Width="120"/>
                                        <DataGridTextColumn Header="Final Status" Binding="{Binding FinalStatus}" Width="160"/>
                                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="320"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="16"
                                Padding="16">
                            <TextBlock Text="{Binding ThirdPassSummaryText}"
                                       Foreground="{StaticResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>